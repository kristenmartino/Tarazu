# Anthropic API (for AI Strategy Advisor)
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the models used by each AI route.
# Defaults: claude-opus-4-7 (analysis), claude-sonnet-4-6 (score suggestions)
ANTHROPIC_MODEL_ANALYSIS=claude-opus-4-7
ANTHROPIC_MODEL_SUGGESTIONS=claude-sonnet-4-6

# Clerk Authentication (https://dashboard.clerk.com)
# Optional — app works in guest mode without these
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# The landing CTAs link to these dedicated pages. Without a publishable key,
# /sign-in and /sign-up redirect to /app (guest mode), so links never dead-end.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase Database (https://supabase.com)
# Optional — app uses localStorage without these
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Analytics (optional)
# Set this to enable the GA script; leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=
